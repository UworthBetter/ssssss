<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ueit.health.mapper.UeitTempMapper">

    <resultMap type="UeitTemp" id="UeitTempResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="value"    column="value"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectUeitTempVo">
        select id, user_id, device_id, value, create_time from ueit_temp
    </sql>

    <select id="selectUeitTempList" parameterType="UeitTemp" resultMap="UeitTempResult">
        <include refid="selectUeitTempVo"/>
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="deviceId != null "> and device_id = #{deviceId}</if>
            <if test="value != null "> and value = #{value}</if>
        </where>
        order by id desc
    </select>

    <select id="selectUeitTempById" parameterType="Long" resultMap="UeitTempResult">
        <include refid="selectUeitTempVo"/>
        where id = #{id}
    </select>
    <select id="getDataBoard" resultType="com.ueit.health.domain.UeitTemp">
        select id, user_id, device_id, value, create_time as readTime from ueit_temp
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="beginReadTime != null and endReadTime != null"> and create_time BETWEEN #{beginReadTime} AND #{endReadTime}</if>
        </where>
    </select>

    <insert id="insertUeitTemp" parameterType="UeitTemp" useGeneratedKeys="true" keyProperty="id">
        insert into ueit_temp
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="deviceId != null">device_id,</if>
            <if test="value != null">value,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="deviceId != null">#{deviceId},</if>
            <if test="value != null">#{value},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateUeitTemp" parameterType="UeitTemp">
        update ueit_temp
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="value != null">value = #{value},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUeitTempById" parameterType="Long">
        delete from ueit_temp where id = #{id}
    </delete>

    <delete id="deleteUeitTempByIds" parameterType="String">
        delete from ueit_temp where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
