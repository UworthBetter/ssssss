<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qkyd.health.mapper.HealthSubjectImportLogMapper">

    <resultMap type="HealthSubjectImportLog" id="HealthSubjectImportLogResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="userName"    column="user_name"    />
        <result property="importType"    column="import_type"    />
        <result property="fileName"    column="file_name"    />
        <result property="filePath"    column="file_path"    />
        <result property="totalRows"    column="total_rows"    />
        <result property="successRows"    column="success_rows"    />
        <result property="failRows"    column="fail_rows"    />
        <result property="status"    column="status"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="costTime"    column="cost_time"    />
        <result property="errorMsg"    column="error_msg"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectHealthSubjectImportLogVo">
        select id, user_id, user_name, import_type, file_name, file_path, total_rows, success_rows, fail_rows,
               status, start_time, end_time, cost_time, error_msg, remark, create_time, update_time
        from health_subject_import_log
    </sql>

    <select id="selectHealthSubjectImportLogList" parameterType="HealthSubjectImportLog" resultMap="HealthSubjectImportLogResult">
        <include refid="selectHealthSubjectImportLogVo"/>
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="userName != null  and userName != ''"> and user_name like concat('%', #{userName}, '%')</if>
            <if test="importType != null  and importType != ''"> and import_type = #{importType}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(start_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(start_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectHealthSubjectImportLogById" parameterType="Long" resultMap="HealthSubjectImportLogResult">
        <include refid="selectHealthSubjectImportLogVo"/>
        where id = #{id}
    </select>

    <select id="selectByUserId" parameterType="Long" resultMap="HealthSubjectImportLogResult">
        <include refid="selectHealthSubjectImportLogVo"/>
        where user_id = #{userId}
        order by create_time desc
    </select>

    <select id="countImportByUserAndType" resultType="int">
        select count(*) from health_subject_import_log
        where user_id = #{userId}
        <if test="importType != null and importType != ''">
            and import_type = #{importType}
        </if>
    </select>

    <insert id="insertHealthSubjectImportLog" parameterType="HealthSubjectImportLog" useGeneratedKeys="true" keyProperty="id">
        insert into health_subject_import_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="importType != null">import_type,</if>
            <if test="fileName != null">file_name,</if>
            <if test="filePath != null">file_path,</if>
            <if test="totalRows != null">total_rows,</if>
            <if test="successRows != null">success_rows,</if>
            <if test="failRows != null">fail_rows,</if>
            <if test="status != null">status,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="costTime != null">cost_time,</if>
            <if test="errorMsg != null">error_msg,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="importType != null">#{importType},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="totalRows != null">#{totalRows},</if>
            <if test="successRows != null">#{successRows},</if>
            <if test="failRows != null">#{failRows},</if>
            <if test="status != null">#{status},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="costTime != null">#{costTime},</if>
            <if test="errorMsg != null">#{errorMsg},</if>
            <if test="remark != null">#{remark},</if>
            now()
         </trim>
    </insert>

    <update id="updateHealthSubjectImportLog" parameterType="HealthSubjectImportLog">
        update health_subject_import_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="importType != null">import_type = #{importType},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="totalRows != null">total_rows = #{totalRows},</if>
            <if test="successRows != null">success_rows = #{successRows},</if>
            <if test="failRows != null">fail_rows = #{failRows},</if>
            <if test="status != null">status = #{status},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="costTime != null">cost_time = #{costTime},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = now()
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteHealthSubjectImportLogById" parameterType="Long">
        delete from health_subject_import_log where id = #{id}
    </delete>

    <delete id="deleteHealthSubjectImportLogByIds" parameterType="Long">
        delete from health_subject_import_log where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
