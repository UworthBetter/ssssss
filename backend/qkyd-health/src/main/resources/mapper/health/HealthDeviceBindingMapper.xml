<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qkyd.health.mapper.HealthDeviceBindingMapper">

    <resultMap type="HealthDeviceBinding" id="HealthDeviceBindingResult">
        <result property="id"    column="id"    />
        <result property="subjectId"    column="subject_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="bindTime"    column="bind_time"    />
        <result property="status"    column="status"    />
        <result property="bindBy"    column="bind_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectHealthDeviceBindingVo">
        select id, subject_id, device_id, bind_time, status, bind_by, create_time, update_by, update_time from health_device_binding
    </sql>

    <select id="selectHealthDeviceBindingList" parameterType="HealthDeviceBinding" resultMap="HealthDeviceBindingResult">
        <include refid="selectHealthDeviceBindingVo"/>
        <where>
            <if test="subjectId != null "> and subject_id = #{subjectId}</if>
            <if test="deviceId != null "> and device_id = #{deviceId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by bind_time desc
    </select>

    <select id="selectHealthDeviceBindingById" parameterType="Long" resultMap="HealthDeviceBindingResult">
        <include refid="selectHealthDeviceBindingVo"/>
        where id = #{id}
    </select>

    <select id="selectBySubjectId" parameterType="Long" resultMap="HealthDeviceBindingResult">
        <include refid="selectHealthDeviceBindingVo"/>
        where subject_id = #{subjectId} and status = '1'
        order by bind_time desc
    </select>

    <select id="selectByDeviceId" parameterType="Long" resultMap="HealthDeviceBindingResult">
        <include refid="selectHealthDeviceBindingVo"/>
        where device_id = #{deviceId} and status = '1'
    </select>

    <select id="checkDeviceBinding" parameterType="Long" resultType="int">
        select count(*) from health_device_binding 
        where device_id = #{deviceId} and status = '1'
    </select>

    <insert id="insertHealthDeviceBinding" parameterType="HealthDeviceBinding" useGeneratedKeys="true" keyProperty="id">
        insert into health_device_binding
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="subjectId != null">subject_id,</if>
            <if test="deviceId != null">device_id,</if>
            <if test="bindTime != null">bind_time,</if>
            <if test="status != null">status,</if>
            <if test="bindBy != null">bind_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="subjectId != null">#{subjectId},</if>
            <if test="deviceId != null">#{deviceId},</if>
            <if test="bindTime != null">#{bindTime},</if>
            <if test="status != null">#{status},</if>
            <if test="bindBy != null">#{bindBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateHealthDeviceBinding" parameterType="HealthDeviceBinding">
        update health_device_binding
        <trim prefix="SET" suffixOverrides=",">
            <if test="subjectId != null">subject_id = #{subjectId},</if>
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="bindTime != null">bind_time = #{bindTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="bindBy != null">bind_by = #{bindBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <update id="unbindDevice" parameterType="Long">
        update health_device_binding set status = '0', update_time = now() where id = #{id}
    </update>

    <delete id="deleteHealthDeviceBindingById" parameterType="Long">
        delete from health_device_binding where id = #{id}
    </delete>

    <delete id="deleteHealthDeviceBindingByIds" parameterType="Long">
        delete from health_device_binding where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
