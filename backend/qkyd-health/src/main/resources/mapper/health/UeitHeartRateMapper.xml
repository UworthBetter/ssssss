<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qkyd.health.mapper.UeitHeartRateMapper">

    <resultMap type="UeitHeartRate" id="UeitHeartRateResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="value"    column="value"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectUeitHeartRateVo">
        select id, user_id, device_id, value, create_time from qkyd_heart_rate
    </sql>

    <select id="selectUeitHeartRateList" parameterType="UeitHeartRate" resultMap="UeitHeartRateResult">
        <include refid="selectUeitHeartRateVo"/>
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="deviceId != null "> and device_id = #{deviceId}</if>
            <if test="value != null "> and value = #{value}</if>
        </where>
        order by id desc
    </select>

    <select id="selectUeitHeartRateById" parameterType="Long" resultMap="UeitHeartRateResult">
        <include refid="selectUeitHeartRateVo"/>
        where id = #{id}
    </select>
    <select id="getDataBoard" resultType="com.qkyd.health.domain.UeitHeartRate">
        SELECT id, user_id, device_id, value, create_time as readTime FROM qkyd_heart_rate
        <where>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="beginReadTime != null and endReadTime != null"> and create_time BETWEEN #{beginReadTime} AND #{endReadTime}</if>
        </where>
    </select>

    <insert id="insertUeitHeartRate" parameterType="UeitHeartRate" useGeneratedKeys="true" keyProperty="id">
        insert into qkyd_heart_rate
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="deviceId != null">device_id,</if>
            <if test="value != null">value,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="deviceId != null">#{deviceId},</if>
            <if test="value != null">#{value},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateUeitHeartRate" parameterType="UeitHeartRate">
        update qkyd_heart_rate
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="value != null">value = #{value},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUeitHeartRateById" parameterType="Long">
        delete from qkyd_heart_rate where id = #{id}
    </delete>

    <delete id="deleteUeitHeartRateByIds" parameterType="String">
        delete from qkyd_heart_rate where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
