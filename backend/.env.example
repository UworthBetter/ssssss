# 复制此文件为 .env，填入真实值，切勿提交 .env 到版本控制
# Copy this file to .env, fill in real values, NEVER commit .env

# DeepSeek / OpenAI 兼容 API Key（必填）
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI 服务基础 URL（默认 DeepSeek）
AI_BASE_URL=https://api.deepseek.com/v1

# 使用的模型名称
AI_MODEL=deepseek-chat
AI_FAST_MODEL=deepseek-chat
AI_REPORT_MODEL=deepseek-chat

# AI 温度参数 (0-2)
AI_TEMPERATURE=0.7

# 数据库
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=qkyd_jkpt
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Token 密钥（生产环境请换成随机强密钥）
TOKEN_SECRET=your_random_secret_here

# 日志文件路径
LOG_FILE=/app/logs/qkyd.log
